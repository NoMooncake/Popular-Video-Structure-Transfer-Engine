PORT=4000
UPLOAD_DIR=uploads
OUTPUT_DIR=outputs
MAX_UPLOAD_FILE_SIZE_MB=200

# LLM provider for structure extraction.
# For Volcengine Ark / Doubao, LLM_ENDPOINT_ID is the endpoint id used as the chat completion model.
LLM_PROVIDER=doubao
LLM_MODEL=Doubao-Seed-2.0-lite
LLM_API_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
LLM_ENDPOINT_ID=
LLM_API_KEY=
SEEDANCE_API_KEY=
ARK_API_KEY=

# Optional future providers for text-to-image and image-to-video gap filling.
AIGC_IMAGE_API_KEY=
AIGC_VIDEO_API_KEY=

# V2 API-first providers. Keep actual provider URLs and keys in local .env only.
V2_MULTIMODAL_PROVIDER=xiaomi
V2_MULTIMODAL_API_BASE_URL=
V2_MULTIMODAL_API_PATH=/chat/completions
V2_MULTIMODAL_MODEL=
V2_MULTIMODAL_API_KEY=

V2_IMAGE_PROVIDER=volcengine_seedream
V2_IMAGE_API_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
V2_IMAGE_API_PATH=/images/generations
V2_IMAGE_MODEL=
V2_IMAGE_API_KEY=

V2_VIDEO_PROVIDER=seedance
V2_VIDEO_API_BASE_URL=
V2_VIDEO_API_PATH=/videos/generations
V2_VIDEO_MODEL=
V2_VIDEO_API_KEY=
