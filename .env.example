PORT=4000
UPLOAD_DIR=uploads
OUTPUT_DIR=outputs
MAX_UPLOAD_FILE_SIZE_MB=200

# LLM provider for structure extraction.
# For Volcengine Ark / Doubao, LLM_ENDPOINT_ID is the endpoint id used as the chat completion model.
LLM_PROVIDER=doubao
LLM_MODEL=Doubao-Seed-2.0-lite
LLM_API_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
LLM_ENDPOINT_ID=
LLM_API_KEY=
SEEDANCE_API_KEY=

# Optional future providers for text-to-image and image-to-video gap filling.
AIGC_IMAGE_API_KEY=
AIGC_VIDEO_API_KEY=
