{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/NoMooncake/Popular-Video-Structure-Transfer-Engine/schemas/slot_mapping.schema.json",
  "title": "Slot Mapping",
  "description": "结构迁移阶段的槽位匹配结果，描述样例结构槽位如何映射到新主题和用户素材。",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "version",
    "created_at",
    "source",
    "target",
    "mappings",
    "summary"
  ],
  "properties": {
    "id": {
      "type": "string",
      "minLength": 1
    },
    "version": {
      "type": "string",
      "minLength": 1
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "source": {
      "$ref": "#/$defs/source"
    },
    "target": {
      "$ref": "#/$defs/target"
    },
    "mappings": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/slot_mapping_item"
      }
    },
    "summary": {
      "$ref": "#/$defs/summary"
    }
  },
  "$defs": {
    "source": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "type",
        "structure_blueprint_ref",
        "material_analysis_ref",
        "model"
      ],
      "properties": {
        "type": {
          "type": "string",
          "enum": [
            "rule",
            "mock",
            "manual",
            "llm"
          ]
        },
        "structure_blueprint_ref": {
          "type": "string"
        },
        "material_analysis_ref": {
          "type": "string"
        },
        "model": {
          "type": "string"
        }
      }
    },
    "target": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "target_topic": {
          "type": "string"
        },
        "selling_points": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "slot_mapping_item": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "slot_id",
        "slot_type",
        "time_range",
        "original_content_goal",
        "adapted_content_goal",
        "matched_material_refs",
        "matched_segment_refs",
        "match_confidence",
        "material_status",
        "missing_material",
        "missing_reasons",
        "suggested_copy",
        "packaging_suggestions",
        "migration_notes"
      ],
      "properties": {
        "slot_id": {
          "type": "string",
          "minLength": 1
        },
        "slot_type": {
          "type": "string",
          "minLength": 1
        },
        "time_range": {
          "$ref": "#/$defs/time_range"
        },
        "original_content_goal": {
          "type": "string"
        },
        "adapted_content_goal": {
          "type": "string"
        },
        "required_materials": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "matched_material_refs": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "uniqueItems": true
        },
        "matched_segment_refs": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "uniqueItems": true
        },
        "match_confidence": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "material_status": {
          "type": "string",
          "enum": [
            "matched",
            "partial",
            "missing"
          ]
        },
        "missing_material": {
          "type": "boolean"
        },
        "missing_reasons": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "suggested_copy": {
          "type": "string"
        },
        "packaging_suggestions": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "migration_notes": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "summary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "total_slots",
        "matched_slots",
        "partial_slots",
        "missing_slots",
        "ready_for_gap_detection",
        "ready_for_timeline",
        "notes"
      ],
      "properties": {
        "total_slots": {
          "type": "integer",
          "minimum": 0
        },
        "matched_slots": {
          "type": "integer",
          "minimum": 0
        },
        "partial_slots": {
          "type": "integer",
          "minimum": 0
        },
        "missing_slots": {
          "type": "integer",
          "minimum": 0
        },
        "ready_for_gap_detection": {
          "type": "boolean"
        },
        "ready_for_timeline": {
          "type": "boolean"
        },
        "notes": {
          "type": "string"
        }
      }
    },
    "time_range": {
      "oneOf": [
        {
          "type": "string",
          "minLength": 1
        },
        {
          "type": "object",
          "additionalProperties": true
        }
      ]
    }
  }
}
