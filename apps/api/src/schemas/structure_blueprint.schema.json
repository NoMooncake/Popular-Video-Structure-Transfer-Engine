{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/NoMooncake/Popular-Video-Structure-Transfer-Engine/schemas/structure_blueprint.schema.json",
  "title": "Structure Blueprint",
  "description": "从样例视频中抽取出的可迁移结构蓝图，描述脚本、节奏、包装和迁移规则。",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "version",
    "created_at",
    "source",
    "vertical",
    "slots"
  ],
  "properties": {
    "id": {
      "type": "string",
      "minLength": 1
    },
    "version": {
      "type": "string",
      "minLength": 1
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "source": {
      "$ref": "#/$defs/source"
    },
    "sample_analysis_ref": {
      "type": "string"
    },
    "vertical": {
      "type": "string",
      "minLength": 1
    },
    "category": {
      "type": "string"
    },
    "summary": {
      "type": "string"
    },
    "detected_structures": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": [
          "script",
          "rhythm",
          "packaging",
          "visual",
          "audio"
        ]
      },
      "uniqueItems": true
    },
    "slots": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/structure_slot"
      }
    },
    "global_rhythm": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "pace": {
          "type": "string",
          "enum": [
            "slow",
            "medium",
            "fast",
            "mixed"
          ]
        },
        "shot_frequency": {
          "type": "string"
        },
        "climax_position": {
          "$ref": "#/$defs/time_range"
        },
        "notes": {
          "type": "string"
        }
      }
    },
    "packaging_summary": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "subtitle_density": {
          "type": "string",
          "enum": [
            "none",
            "low",
            "medium",
            "high"
          ]
        },
        "title_style": {
          "type": "string"
        },
        "highlight_style": {
          "type": "string"
        },
        "transition_style": {
          "type": "string"
        },
        "cover_style": {
          "type": "string"
        }
      }
    }
  },
  "$defs": {
    "source": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "type"
      ],
      "properties": {
        "type": {
          "type": "string",
          "enum": [
            "sample_analysis",
            "reference_video",
            "mock",
            "manual",
            "llm"
          ]
        },
        "ref_id": {
          "type": "string"
        },
        "model": {
          "type": "string"
        },
        "prompt_version": {
          "type": "string"
        }
      }
    },
    "structure_slot": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "slot_id",
        "slot_type",
        "time_range",
        "content_goal",
        "rhythm",
        "required_materials",
        "packaging_features",
        "migration_rule"
      ],
      "properties": {
        "slot_id": {
          "type": "string",
          "minLength": 1
        },
        "slot_type": {
          "type": "string",
          "minLength": 1
        },
        "time_range": {
          "$ref": "#/$defs/time_range"
        },
        "content_goal": {
          "type": "string",
          "minLength": 1
        },
        "rhythm": {
          "type": "string",
          "enum": [
            "slow",
            "medium",
            "fast",
            "mixed"
          ]
        },
        "required_materials": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/material_requirement"
          }
        },
        "packaging_features": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/packaging_feature"
          }
        },
        "migration_rule": {
          "type": "string",
          "minLength": 1
        },
        "source_evidence": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "confidence": {
          "$ref": "#/$defs/confidence"
        }
      }
    },
    "material_requirement": {
      "oneOf": [
        {
          "type": "string",
          "minLength": 1
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "type",
            "description"
          ],
          "properties": {
            "type": {
              "type": "string"
            },
            "description": {
              "type": "string"
            },
            "priority": {
              "type": "string",
              "enum": [
                "required",
                "recommended",
                "optional"
              ]
            }
          }
        }
      ]
    },
    "packaging_feature": {
      "oneOf": [
        {
          "type": "string",
          "minLength": 1
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "type"
          ],
          "properties": {
            "type": {
              "type": "string"
            },
            "description": {
              "type": "string"
            },
            "style": {
              "type": "string"
            }
          }
        }
      ]
    },
    "time_range": {
      "oneOf": [
        {
          "type": "string",
          "minLength": 1
        },
        {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "label": {
              "type": "string"
            },
            "start_seconds": {
              "type": "number",
              "minimum": 0
            },
            "end_seconds": {
              "type": "number",
              "minimum": 0
            },
            "relative_start_percent": {
              "type": "number",
              "minimum": 0,
              "maximum": 100
            },
            "relative_end_percent": {
              "type": "number",
              "minimum": 0,
              "maximum": 100
            }
          },
          "minProperties": 1
        }
      ]
    },
    "confidence": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    }
  }
}
