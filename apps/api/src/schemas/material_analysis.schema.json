{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/NoMooncake/Popular-Video-Structure-Transfer-Engine/schemas/material_analysis.schema.json",
  "title": "Material Analysis",
  "description": "用户上传素材的基础理解结果，用于判断素材能匹配哪些结构槽位。",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "version",
    "created_at",
    "source",
    "materials",
    "segments"
  ],
  "properties": {
    "id": {
      "type": "string",
      "minLength": 1
    },
    "version": {
      "type": "string",
      "minLength": 1
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "source": {
      "$ref": "#/$defs/source"
    },
    "target_content_ref": {
      "type": "string"
    },
    "materials": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/material"
      }
    },
    "segments": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/material_segment"
      }
    },
    "coverage_summary": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "supported_slot_types": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "uniqueItems": true
        },
        "weak_slot_types": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "uniqueItems": true
        },
        "notes": {
          "type": "string"
        }
      }
    }
  },
  "$defs": {
    "source": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "type"
      ],
      "properties": {
        "type": {
          "type": "string",
          "enum": [
            "uploaded_materials",
            "mock",
            "manual",
            "llm"
          ]
        },
        "project_id": {
          "type": "string"
        },
        "model": {
          "type": "string"
        }
      }
    },
    "material": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "material_id",
        "type",
        "description"
      ],
      "properties": {
        "material_id": {
          "type": "string",
          "minLength": 1
        },
        "type": {
          "type": "string",
          "enum": [
            "video",
            "image",
            "copy",
            "audio",
            "other"
          ]
        },
        "uri": {
          "type": "string"
        },
        "description": {
          "type": "string"
        },
        "tags": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "metadata": {
          "type": "object",
          "additionalProperties": true
        }
      }
    },
    "material_segment": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "segment_id",
        "material_ref",
        "content",
        "tags",
        "recommended_slot"
      ],
      "properties": {
        "segment_id": {
          "type": "string",
          "minLength": 1
        },
        "material_ref": {
          "type": "string",
          "minLength": 1
        },
        "time_range": {
          "$ref": "#/$defs/time_range"
        },
        "content": {
          "type": "string"
        },
        "tags": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "recommended_slot": {
          "type": "string"
        },
        "quality_score": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "usable": {
          "type": "boolean"
        },
        "limitations": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "time_range": {
      "oneOf": [
        {
          "type": "string",
          "minLength": 1
        },
        {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "label": {
              "type": "string"
            },
            "start_seconds": {
              "type": "number",
              "minimum": 0
            },
            "end_seconds": {
              "type": "number",
              "minimum": 0
            }
          },
          "minProperties": 1
        }
      ]
    }
  }
}
