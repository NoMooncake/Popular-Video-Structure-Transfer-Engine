{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/NoMooncake/Popular-Video-Structure-Transfer-Engine/schemas/demo_case.schema.json",
  "title": "Demo Case",
  "description": "MVP demo case 定义，用于描述参考样例、目标内容、用户素材、预期缺口和可替换策略。",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "case_id",
    "version",
    "case_name",
    "vertical",
    "category_mode",
    "primary_demo_category",
    "language",
    "source_sample",
    "target_output",
    "target_content",
    "user_materials",
    "expected_transfer_timeline",
    "expected_gaps",
    "replacement_policy"
  ],
  "properties": {
    "case_id": {
      "type": "string",
      "minLength": 1
    },
    "version": {
      "type": "string",
      "minLength": 1
    },
    "case_name": {
      "type": "string",
      "minLength": 1
    },
    "vertical": {
      "type": "string",
      "minLength": 1
    },
    "category_mode": {
      "type": "string",
      "enum": [
        "single_category",
        "multi_category"
      ]
    },
    "primary_demo_category": {
      "type": "string",
      "minLength": 1
    },
    "language": {
      "type": "string",
      "minLength": 1
    },
    "source_sample": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "status",
        "duration_range_seconds",
        "reference_videos",
        "general_structure_slots"
      ],
      "properties": {
        "status": {
          "type": "string"
        },
        "duration_range_seconds": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "min",
            "max"
          ],
          "properties": {
            "min": {
              "type": "number",
              "minimum": 0
            },
            "max": {
              "type": "number",
              "minimum": 0
            },
            "typical": {
              "type": "number",
              "minimum": 0
            }
          }
        },
        "reference_videos": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "reference_id",
              "category",
              "content_type",
              "role",
              "structure_summary"
            ],
            "properties": {
              "reference_id": {
                "type": "string"
              },
              "category": {
                "type": "string"
              },
              "content_type": {
                "type": "string"
              },
              "role": {
                "type": "string",
                "enum": [
                  "primary_reference",
                  "secondary_reference"
                ]
              },
              "structure_summary": {
                "type": "string"
              },
              "url": {
                "type": "string"
              }
            }
          }
        },
        "general_structure_slots": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "slot_type",
              "relative_position",
              "purpose",
              "transferability"
            ],
            "properties": {
              "slot_type": {
                "type": "string"
              },
              "relative_position": {
                "type": "string"
              },
              "purpose": {
                "type": "string"
              },
              "transferability": {
                "type": "string",
                "enum": [
                  "low",
                  "medium",
                  "high"
                ]
              }
            }
          }
        }
      }
    },
    "target_output": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "duration_seconds",
        "aspect_ratio",
        "platform_style",
        "output_forms"
      ],
      "properties": {
        "duration_seconds": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "recommended_for_mvp"
          ],
          "properties": {
            "recommended_for_mvp": {
              "type": "number",
              "minimum": 1
            },
            "compressed_demo_optional": {
              "type": "number",
              "minimum": 1
            }
          }
        },
        "aspect_ratio": {
          "type": "string"
        },
        "platform_style": {
          "type": "string"
        },
        "output_forms": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string"
          },
          "uniqueItems": true
        }
      }
    },
    "target_content": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "topic",
        "category",
        "target_audience",
        "selling_points"
      ],
      "properties": {
        "topic": {
          "type": "string"
        },
        "category": {
          "type": "string"
        },
        "product_mode": {
          "type": "string"
        },
        "target_audience": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "core_angle": {
          "type": "string"
        },
        "positioning": {
          "type": "string"
        },
        "selling_points": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "possible_objections": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "desired_tone": {
          "type": "string"
        }
      }
    },
    "user_materials": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "status",
        "available",
        "missing"
      ],
      "properties": {
        "status": {
          "type": "string"
        },
        "available": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/material_note"
          }
        },
        "missing": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "missing_id",
              "description"
            ],
            "properties": {
              "missing_id": {
                "type": "string"
              },
              "description": {
                "type": "string"
              }
            }
          }
        }
      }
    },
    "expected_transfer_timeline": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "time_range",
          "slot_type",
          "content_goal",
          "example_copy"
        ],
        "properties": {
          "time_range": {
            "type": "string"
          },
          "slot_type": {
            "type": "string"
          },
          "content_goal": {
            "type": "string"
          },
          "example_copy": {
            "type": "string"
          }
        }
      }
    },
    "expected_gaps": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "gap_id",
          "slot_type",
          "missing",
          "preferred_strategy"
        ],
        "properties": {
          "gap_id": {
            "type": "string"
          },
          "slot_type": {
            "type": "string"
          },
          "missing": {
            "type": "string"
          },
          "preferred_strategy": {
            "type": "string"
          }
        }
      }
    },
    "replacement_policy": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "is_fixed_final_demo",
        "description",
        "can_replace",
        "should_keep_stable"
      ],
      "properties": {
        "is_fixed_final_demo": {
          "type": "boolean"
        },
        "description": {
          "type": "string"
        },
        "can_replace": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "should_keep_stable": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "notes": {
      "type": "object",
      "additionalProperties": {
        "type": "string"
      }
    }
  },
  "$defs": {
    "material_note": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "material_id",
        "type",
        "description"
      ],
      "properties": {
        "material_id": {
          "type": "string"
        },
        "type": {
          "type": "string"
        },
        "description": {
          "type": "string"
        }
      }
    }
  }
}
